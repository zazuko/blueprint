@prefix blueprint: <https://flux.described.at/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

blueprint: a owl:Ontology ;
        rdfs:label "Blueprint Ontology" ;
        rdfs:comment "This is the Blueprint Ontology" ;
        owl:imports <http://www.w3.org/2002/07/owl#> ;
.


blueprint:Child a rdfs:Class ;
        rdfs:label "Child" ;
        rdfs:comment "insert text" ;
.
blueprint:Composition a rdfs:Class ;
        rdfs:label "Composition" ;
        rdfs:comment "insert text" ;
.
blueprint:CompositionLinkResult a rdfs:Class ;
