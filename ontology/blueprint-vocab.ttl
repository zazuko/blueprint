        rdfs:comment "insert text" ;
.
blueprint:CompositionToNodeLink a rdfs:Class ;
        rdfs:label "CompositionToNodeLink" ;
        rdfs:comment "insert text" ;
.
blueprint:ConnectionPoint a rdfs:Class ;
